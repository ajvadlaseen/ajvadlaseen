---
import '../styles/globals.css'
import Hero from '@/components/Hero.astro'
import { ModeToggle } from '@/components/ModeToggle'
import { TabNavigation } from '@/components/TabNavigation'
import { Particles } from '@/components/ui/particles'
import { ClientRouter } from 'astro:transitions'
---

<!doctype html>
<html lang='en'>
    <head>
        <meta charset='UTF-8' />
        <meta name='viewport' content='width=device-width' />
        <link rel='icon' type='image/svg+xml' href='/favicon.svg' />
        <meta name='generator' content={Astro.generator} />
        <title>Ajvad Laseen - Software Developer</title>

        <ClientRouter />
    </head>
    <body class='bg-secondary-background max-h-dvh'>
        <!-- Shared Components across all pages -->
        <div class='fixed top-4 right-4 z-50'>
            <ModeToggle client:load />
        </div>
        <Hero />

        <TabNavigation client:load currentPath={Astro.url.pathname} />

        <div class='mx-auto flex max-w-3xl my-2'>
            <slot />
        </div>
    </body>
</html>

<style>
    html,
    body {
        margin: 0;
        width: 100%;
    }
</style>

<script is:inline>
    const getThemePreference = () => {
        if (
            typeof localStorage !== 'undefined' &&
            localStorage.getItem('theme')
        ) {
            return localStorage.getItem('theme')
        }
        return window.matchMedia('(prefers-color-scheme: dark)').matches
            ? 'dark'
            : 'light'
    }
    const isDark = getThemePreference() === 'dark'
    document.documentElement.classList[isDark ? 'add' : 'remove']('dark')

    if (typeof localStorage !== 'undefined') {
        const observer = new MutationObserver(() => {
            const isDark = document.documentElement.classList.contains('dark')
            localStorage.setItem('theme', isDark ? 'dark' : 'light')
        })
        observer.observe(document.documentElement, {
            attributes: true,
            attributeFilter: ['class'],
        })
    }
</script>
